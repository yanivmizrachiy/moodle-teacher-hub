# Moodle Teacher Hub — environment template
# Copy this file to .env locally and fill only local/private values.
# Never commit .env or secrets to GitHub.

# Public Supabase frontend values
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server / Supabase Edge Function secrets — server side only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LTI 1.x configuration
LTI_CONSUMER_KEY=
LTI_CONSUMER_SECRET=
LTI_LAUNCH_URL=
LTI_SESSION_TTL_HOURS=8

# Optional future Moodle Web Services adapter
# Leave empty until a real Moodle Web Services token exists and is verified.
MOODLE_WS_BASE_URL=
MOODLE_WS_TOKEN=
MOODLE_WS_ENABLED=false

# Local development
APP_BASE_URL=http://127.0.0.1:5173
NODE_ENV=development
