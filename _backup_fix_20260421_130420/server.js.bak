import express from "express";
import helmet from "helmet";
import cookieParser from "cookie-parser";
import fs from "fs";
import path from "path";
import { v4 as uuidv4 } from "uuid";
import { fileURLToPath } from "url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const ROOT = path.dirname(__dirname);
const PORT = 3000;
const STORE_PATH = path.join(ROOT, "data", "store.json");

function loadStore() {
  try {
    return JSON.parse(fs.readFileSync(STORE_PATH, "utf8"));
  } catch {
    return { launches: [] };
  }
}
function saveStore(store) {
  fs.writeFileSync(STORE_PATH, JSON.stringify(store, null, 2), "utf8");
}
const store = loadStore();

const app = express();
app.use(helmet({ contentSecurityPolicy: false }));
app.use(express.json());
app.use(express.urlencoded({ extended: true }));
app.use(cookieParser());

const sessions = new Map();

function setSession(res, data) {
  const sid = uuidv4();
  sessions.set(sid, data);
  res.cookie("sid", sid, { httpOnly: true, sameSite: "lax", secure: false });
}
function getSession(req) {
  const sid = req.cookies?.sid;
  return sid && sessions.has(sid) ? sessions.get(sid) : null;
}
function logLaunch(type, ok, teacherName, spaceTitle, error="") {
  store.launches.push({
    id: uuidv4(),
    type,
    ok,
    teacherName: teacherName || "",
    spaceTitle: spaceTitle || "",
    error,
    createdAt: new Date().toISOString()
  });
  saveStore(store);
}

app.get("/health", (_req, res) => {
  res.json({
    ok: true,
    service: "moodle-teacher-hub",
    now: new Date().toISOString(),
    launches: store.launches.length
  });
});

app.get("/dev/login", (_req, res) => {
  const teacher = "מורה לדוגמה";
  const space = "מרחב לדוגמה";
  logLaunch("dev", true, teacher, space, "");
  setSession(res, {
    teacherName: teacher,
    spaceTitle: space,
    source: "dev-login",
    launchAt: new Date().toISOString()
  });
  return res.redirect("/");
});

app.get("/api/launches", (_req, res) => {
  res.json(store.launches.slice().reverse());
});

app.get("/api/bootstrap", (req, res) => {
  const session = getSession(req);
  if (!session) {
    return res.status(401).json({ ok: false, error: "NO_SESSION" });
  }
  return res.json({
    ok: true,
    teacher: { name: session.teacherName },
    space: { title: session.spaceTitle },
    source: session.source,
    dashboard: {
      launches: store.launches.length,
      totalStudents: 0,
      totalTasks: 0,
      missingSubmissions: 0,
      missingScores: 0
    },
    recommendations: [
      "שלב החיבור עובד",
      "השלב הבא הוא לחבר נתוני תלמידים, משימות וציונים אמיתיים",
      "אפשר כעת להמשיך לבניית מסכי מורה חזקים"
    ]
  });
});

app.get("/", (req, res) => {
  const session = getSession(req);
  if (!session) {
    return res.send('<html lang="he" dir="rtl"><body style="font-family:Arial;padding:30px"><h1>מרכז משימות ודוחות</h1><p>אין session פעיל.</p><p><a href="/dev/login">כניסת בדיקה</a></p></body></html>');
  }
  res.sendFile(path.join(__dirname, "views", "dashboard.html"));
});

app.listen(PORT, () => {
  console.log(`moodle-teacher-hub running on http://127.0.0.1:${PORT}`);
});
